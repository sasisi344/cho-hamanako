---
import { ADSENSE, SITE, SOCIALS } from "@consts"
import {
  buildDefaultJsonLd,
  mergeJsonLdGraphs,
  serializeJsonLd,
} from "@lib/jsonld"
import { withTrailingSlash } from "@lib/paths"

interface Props {
  title: string
  description: string
  image?: string
  noindex?: boolean
  hasAds?: boolean
  /** Open Graph type. Use `article` for blog/point posts. */
  ogType?: "website" | "article"
  /** Article / BreadcrumbList など BaseHead 内の WebSite・Organization に追加するノード */
  jsonLdExtra?: Record<string, unknown>[]
}

const canonicalURL = new URL(withTrailingSlash(Astro.url.pathname), Astro.site)

const {
  title,
  description,
  image = "/open-graph.jpg",
  noindex = false,
  hasAds = false,
  ogType = "website",
  jsonLdExtra,
} = Astro.props

const siteUrl =
  Astro.site == null
    ? "https://cho-hamanako.info"
    : typeof Astro.site === "string"
      ? Astro.site
      : Astro.site.href

const defaultJsonLd = buildDefaultJsonLd({
  siteUrl,
  siteName: SITE.TITLE,
  siteDescription: SITE.DESCRIPTION,
  authorName: SITE.AUTHOR,
  socialProfileUrls: SOCIALS.map((s) => s.HREF),
})

const jsonLdMerged = jsonLdExtra?.length
  ? mergeJsonLdGraphs(defaultJsonLd, jsonLdExtra)
  : defaultJsonLd

const jsonLdHtml = serializeJsonLd(jsonLdMerged)

const ogUrl = canonicalURL.href
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" type="image/png" href="/favicon.png" />
<meta name="generator" content={Astro.generator} />
{noindex && <meta name="robots" content="noindex" />}

<!-- Google tag (gtag.js) via Partytown -->
<script is:inline type="text/partytown" src="https://www.googletagmanager.com/gtag/js?id=G-EC504C30T1"></script>
<script is:inline type="text/partytown">
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());

  gtag('config', 'G-EC504C30T1');
</script>

<!-- Main-thread gtag shim: forwards to the Partytown-worker gtag.js above via dataLayer.push (see astro.config.mjs forward: ["dataLayer.push"]) -->
<script is:inline>
  window.dataLayer = window.dataLayer || [];
  window.gtag = window.gtag || function () { window.dataLayer.push(arguments); };
</script>

<link rel="preload" href="/fonts/atkinson-regular.woff" as="font" type="font/woff" crossorigin>
<link rel="preload" href="/fonts/atkinson-bold.woff" as="font" type="font/woff" crossorigin>

<script is:inline type="application/ld+json" set:html={jsonLdHtml} />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={ogType} />
<meta property="og:url" content={ogUrl} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={new URL(image, Astro.site)} />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={ogUrl} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={new URL(image, Astro.site)} />

<!-- Sitemap -->
<link rel="sitemap" href="/sitemap-index.xml" />

<!-- RSS Feed -->
<link rel="alternate" type="application/rss+xml" title={title} href={`${Astro.site}rss.xml`}/>

<!-- Global Scripts -->
<script is:inline>
  function preloadTheme() {
    const theme = (() => {
      const userTheme = localStorage.theme;
      if (userTheme === "light" || userTheme === "dark") return userTheme;
      return window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
    })();
    const element = document.documentElement;
    if (theme === "dark") element.classList.add("dark");
    else element.classList.remove("dark");
    localStorage.theme = theme;
  }
  preloadTheme();
  document.addEventListener("astro:after-swap", preloadTheme);
</script>

<script>
  import "../scripts/theme.js";
  import "../scripts/scroll.js";
  import "../scripts/animate.js";
  import "../scripts/copy.js";
  import "../scripts/affiliate-tracking.js";
  import "../scripts/scroll-depth.js";
</script>

{hasAds && (
  <script is:inline define:vars={{ clientId: ADSENSE.CLIENT_ID }}>
    let adsLoaded = false;
    function lazyLoadAdSense() {
      if (adsLoaded) return;
      adsLoaded = true;
      const script = document.createElement("script");
      script.src = `https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${clientId}`;
      script.async = true;
      script.crossOrigin = "anonymous";
      document.head.appendChild(script);
      
      const events = ['scroll', 'mousemove', 'touchstart', 'keydown'];
      events.forEach(e => window.removeEventListener(e, lazyLoadAdSense));
    }
    const events = ['scroll', 'mousemove', 'touchstart', 'keydown'];
    events.forEach(e => window.addEventListener(e, lazyLoadAdSense, { passive: true, once: true }));
  </script>
)}
