---
import { getEntry } from "astro:content";
import { Image } from "astro:assets";

interface Props {
  slug?: string;
  url?: string;
  title?: string;
  summary?: string;
  cover?: ImageMetadata | string;
}

const { slug, url, title, summary, cover } = Astro.props;
const entry = slug ? await getEntry("blog", slug) : null;

const finalUrl = url || (entry ? `/blog/${entry.slug}` : "#");
const finalTitle = title || (entry ? entry.data.title : "Link");
const finalSummary = summary || (entry ? entry.data.summary : "");
const finalCover = cover || (entry ? entry.data.cover : null);
const isExternal = url?.startsWith('http');
---

{ (entry || url) ? (
  <a href={finalUrl} target={isExternal ? "_blank" : "_self"} rel={isExternal ? "noopener noreferrer" : ""} class="not-prose group my-6 p-5 flex flex-col sm:flex-row items-center gap-5 border rounded-xl bg-slate-100 hover:bg-slate-200 dark:bg-slate-800 dark:hover:bg-slate-700 border-slate-200 hover:border-slate-300 dark:border-slate-700 dark:hover:border-slate-600 transition-all duration-300 ease-in-out shadow-sm no-underline relative overflow-hidden">
    <div class="flex-1 w-full relative z-10">
      <div class="flex flex-wrap items-center gap-2 mb-2">
        <span class="text-[10px] font-bold uppercase tracking-widest text-slate-600 dark:text-slate-300 bg-slate-200 dark:bg-slate-700 px-2.5 py-1 rounded-full">
          {isExternal ? "外部リンク" : "関連記事"}
        </span>
      </div>
      <div class="font-bold text-lg text-black dark:text-white mb-1.5 leading-snug group-hover:text-slate-700 group-hover:dark:text-slate-300 transition-colors line-clamp-2">
        {finalTitle}
      </div>
      <div class="text-sm text-black/70 dark:text-white/70 line-clamp-2">
        {finalSummary}
      </div>
    </div>
    <div class="hidden sm:flex shrink-0 w-10 h-10 rounded-full bg-slate-200 dark:bg-slate-700 border border-slate-300 dark:border-slate-600 items-center justify-center text-slate-600 dark:text-slate-300 group-hover:bg-slate-500 group-hover:text-white group-hover:dark:bg-slate-500 group-hover:dark:border-slate-500 transition-all duration-300 relative z-10">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-0.5 transition-transform">
        <line x1="5" y1="12" x2="19" y2="12"></line>
        <polyline points="12 5 19 12 12 19"></polyline>
      </svg>
    </div>
    {/* Thumbnail Background Layer */}
    {finalCover && (
      <div class="absolute inset-0 z-0 overflow-hidden rounded-xl transition-colors duration-300">
        {typeof finalCover === 'string' ? (
          <img 
            src={finalCover} 
            alt="" 
            class="w-full h-full object-cover opacity-40 mix-blend-luminosity group-hover:scale-105 group-hover:opacity-50 transition-all duration-700 ease-out" 
          />
        ) : (
          <Image 
            src={finalCover} 
            alt="" 
            class="w-full h-full object-cover opacity-40 mix-blend-luminosity group-hover:scale-105 group-hover:opacity-50 transition-all duration-700 ease-out" 
          />
        )}
        <div class="absolute inset-0 bg-gradient-to-r from-slate-100 via-slate-100/95 to-slate-100/40 dark:from-slate-800 dark:via-slate-800/95 dark:to-slate-800/40 group-hover:from-slate-200 group-hover:via-slate-200/95 group-hover:to-slate-200/40 dark:group-hover:from-slate-700 dark:group-hover:via-slate-700/95 dark:group-hover:to-slate-700/40 transition-colors duration-300"></div>
      </div>
    )}
    {/* Decorative background accent */}
    <div class="absolute right-0 top-0 w-32 h-32 bg-slate-300/50 dark:bg-slate-600/30 rounded-full blur-3xl -mr-10 -mt-10 transition-opacity group-hover:opacity-100 opacity-50 z-0"></div>
  </a>
) : (
  <div class="my-6 p-4 border border-red-500/30 bg-red-500/10 rounded-xl text-red-500 text-sm font-semibold">
    ⚠️ Blog entry "{slug}" not found.
  </div>
)}
