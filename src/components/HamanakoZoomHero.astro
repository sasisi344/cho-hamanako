---
import { Image } from "astro:assets"
import heroImg from "../assets/images/hamanako_actual.webp"
---
<div id="hero-container" class="relative h-screen w-full overflow-hidden bg-slate-900 flex items-center justify-center">
  <!-- Background Layer (Hamanako Image) -->
  <div id="hamanako-layer" class="absolute inset-0 z-10 flex items-center justify-center opacity-0 transition-opacity duration-[3000ms] ease-in-out">
    <div class="absolute inset-0 bg-slate-900/40 z-20"></div> <!-- Dark overlay for better text contrast -->
    <Image src={heroImg} fetchpriority="high" class="w-full h-full object-cover opacity-70" alt="Lake Hamana" widths={[800, 1600]} sizes="100vw" quality={60} loading="eager" decoding="sync" />
  </div>

  <!-- Overlay/Text Layer -->
  <div id="text-layer" class="relative z-30 flex flex-col items-center justify-center text-white text-center px-4">
    <h1 class="text-6xl md:text-8xl font-black mb-4 py-2 leading-tight drop-shadow-[0_5px_15px_rgba(0,0,0,0.8)] tracking-tighter opacity-0 translate-y-4 transition-all duration-1000 ease-out">
      釣！浜名湖
    </h1>
    <p class="text-xl md:text-2xl font-light mb-8 max-w-2xl drop-shadow-md opacity-0 translate-y-4 transition-all duration-1000 delay-300 ease-out">
      浜名湖のすべてを釣り尽くす。ポイント・仕掛け・最新釣果。
    </p>
    <div class="flex gap-4 opacity-0 translate-y-4 transition-all duration-1000 delay-500 ease-out">
      <a href="/map" class="bg-blue-600 hover:bg-blue-700 text-white px-8 py-3 rounded-full font-bold transition-all hover:scale-105 active:scale-95 shadow-xl">
        ポイントを探す
      </a>
      <a href="#featured-points" class="bg-white/10 hover:bg-white/20 backdrop-blur-md text-white border border-white/30 px-8 py-3 rounded-full font-bold transition-all">
        最新ガイドを見る
      </a>
    </div>
  </div>

  <!-- Scroll Indicator -->
  <div id="scroll-indicator" class="absolute bottom-10 left-1/2 -translate-x-1/2 z-40 opacity-0 transition-opacity duration-1000 delay-1000">
    <div class="animate-bounce">
      <svg class="w-8 h-8 text-white/50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
      </svg>
    </div>
  </div>
</div>

<script is:inline>
  window.addEventListener('load', () => {
    const hamanako = document.getElementById('hamanako-layer');
    const textElements = document.querySelectorAll('#text-layer > *');
    const scrollIndicator = document.getElementById('scroll-indicator');

    // Show Text Elements immediately (with slight sequence)
    textElements.forEach(el => {
      el.classList.remove('opacity-0', 'translate-y-4');
    });

    // Fade in Hamanako background after 2 seconds
    setTimeout(() => {
      if (hamanako) {
        hamanako.style.opacity = '1';
      }
    }, 2000);

    // Show scroll indicator
    setTimeout(() => {
      if (scrollIndicator) {
        scrollIndicator.style.opacity = '1';
      }
    }, 1000);
  });
</script>

<style>
  h1 {
    text-shadow: 0 0 30px rgba(0,0,0,0.8);
    background: linear-gradient(to bottom, #fff, #93c5fd);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
</style>

<style>
  #hero-container {
    perspective: 1000px;
  }
  
  h1 {
    text-shadow: 0 0 20px rgba(0,0,0,0.5);
    background: linear-gradient(to bottom, #fff, #93c5fd);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
</style>
