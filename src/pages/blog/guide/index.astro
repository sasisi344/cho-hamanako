---
import { getCollection } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import TopLayout from "@layouts/TopLayout.astro";
import BottomLayout from "@layouts/BottomLayout.astro";
import SearchCollection from "@components/SearchCollection";

const guidePosts = (await getCollection("blog"))
  .filter((post) => !post.data.draft && post.data.category === "guide")
  .sort((a, b) => (b.data.pubDate || b.data.date).getTime() - (a.data.pubDate || a.data.date).getTime());

const title = "初心者向け解説ガイド";
const description = "浜名湖での釣りを始める方に向けた、基礎知識や入門ガイドをまとめています。";

// Extract all unique tags used in guide posts
const activeGuideTags = [...new Set(guidePosts.flatMap((post) => post.data.tags))];

const estimated_initial_size = 28 + guidePosts.length * 158 + (guidePosts.length - 1) * 12;
---

<PageLayout title={title} description={description}>
  <TopLayout>
    <div class="animate">
      <h1 class="text-3xl font-semibold text-black dark:text-white mt-2">
        {title}
      </h1>
      <div class="mt-1">
        {description}
      </div>
    </div>
  </TopLayout>
  <BottomLayout>
    <div
      id="search-collection-wrapper"
      class="animate"
      style={{ minHeight: `${estimated_initial_size}px` }}
    >
      <SearchCollection
        client:load
        entry_name={"guides"}
        tags={activeGuideTags}
        data={guidePosts}
      />
    </div>
  </BottomLayout>
</PageLayout>
