---
import { getCollection } from "astro:content"
import PageLayout from "@layouts/PageLayout.astro"
import ArrowCard from "@components/ArrowCard"
import { SITE } from "@consts"
import HamanakoZoomHero from "@components/HamanakoZoomHero.astro"

const allPosts = await getCollection("blog")
const sortedPosts = allPosts
  .filter(post => !post.data.draft)
  .sort((a, b) => (b.data.pubDate || b.data.pubDate).getTime() - (a.data.pubDate || a.data.pubDate).getTime())

const currentMonth = new Date().getMonth() + 1

const pointPosts = sortedPosts.filter(post => post.data.category === "points")
const currentMonthPoints = pointPosts.filter(post => 
  post.data.fishinginfo && Array.isArray(post.data.fishinginfo.bestSeason) && post.data.fishinginfo.bestSeason.includes(String(currentMonth))
)
const recommendedPoints = currentMonthPoints.sort(() => 0.5 - Math.random())
const displayPoints = [...new Set([...recommendedPoints, ...pointPosts])].slice(0, 6)

const guidePosts = sortedPosts.filter(post => post.data.category === "guide")
const recentGuides = guidePosts.slice(0, 3)

const areas = [
  { name: "表浜名湖", slug: "omote", description: "今切口に近く潮通し抜群。シーバス・青物の回遊も。", image: "/images/omote.webp" },
  { name: "中浜名湖", slug: "naka", description: "広大な干潟が広がる。クロダイの聖地。", image: "/images/naka.webp" },
  { name: "奥浜名湖", slug: "oku", description: "汽水域の豊かさ。ハゼやシーバスの宝庫。", image: "/images/oku.webp" },
]
---

<PageLayout title="浜名湖釣りガイド" description={SITE.DESCRIPTION} hasAds={true}>
  
  <HamanakoZoomHero />

  <div class="relative bg-slate-50 dark:bg-zinc-950">
    <!-- Area Selection -->
    <section class="py-24 px-4 max-w-screen-xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-5xl font-bold text-slate-900 dark:text-white mb-4">エリアから探す</h2>
        <p class="text-slate-600 dark:text-slate-400">浜名湖はエリアによって全く異なる釣りが楽しめます。</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {areas.map(area => (
          <a href={`/map?area=${area.name}`} class="group relative h-80 overflow-hidden rounded-3xl shadow-2xl transition-all hover:-translate-y-2">
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent z-10"></div>
            <img src={area.image} alt={area.name} class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" />
            <div class="absolute bottom-0 left-0 p-8 z-20">
              <h3 class="text-2xl font-bold text-white mb-2">{area.name}</h3>
              <p class="text-white/80 text-sm opacity-0 group-hover:opacity-100 transition-opacity duration-300">{area.description}</p>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- Recommended Points for Current Month -->
    <section id="featured-points" class="py-24 bg-white dark:bg-black">
      <div class="max-w-screen-xl mx-auto px-4">
        <div class="flex flex-col md:flex-row justify-between items-end mb-12 gap-4">
          <div>
            <h2 class="text-3xl md:text-5xl font-bold text-slate-900 dark:text-white mb-4">今月（{currentMonth}月）の注目ポイント</h2>
            <p class="text-slate-600 dark:text-slate-400">実績とデータから厳選した、今行くべき激アツスポット。</p>
          </div>
          <a href="/map" class="text-blue-600 font-bold hover:underline whitespace-nowrap mb-2">すべてのポイントを見る →</a>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {displayPoints.map(post => (
            <ArrowCard entry={post} />
          ))}
        </div>
      </div>
    </section>

    <!-- Guide Section -->
    <section class="py-24 px-4 bg-slate-900 text-white overflow-hidden relative">
      <div class="absolute top-0 right-0 w-1/3 h-full bg-blue-600/10 skew-x-12 transform translate-x-20"></div>
      <div class="max-w-screen-xl mx-auto relative z-10">
        <div class="flex flex-col md:flex-row gap-12 items-center">
          <div class="w-full md:w-1/2">
            <h2 class="text-3xl md:text-5xl font-bold mb-6 italic">Master Lake Hamanako</h2>
            <p class="text-slate-300 mb-8 text-lg">
              潮の読み方から季節ごとのターゲット、最適なタックルまで。浜名湖を攻略するための「知恵」を凝縮しました。
            </p>
            <div class="space-y-4">
              {recentGuides.map(guide => (
                <a href={`/blog/${guide.slug}`} class="block p-4 rounded-xl bg-white/5 border border-white/10 hover:bg-white/10 transition-colors">
                  <span class="text-blue-400 text-xs font-bold uppercase tracking-widest">{guide.data.category}</span>
                  <h4 class="text-lg font-bold mt-1">{guide.data.title}</h4>
                </a>
              ))}
            </div>
          </div>
          <div class="w-full md:w-1/2 grid grid-cols-2 gap-4">
            <div class="space-y-4">
              <!-- Card 1: 仕掛け解説 -->
              <a href="/affiliates" class="group relative block aspect-square rounded-3xl overflow-hidden bg-slate-800/50 backdrop-blur-xl border border-white/10 hover:border-blue-400/50 hover:bg-slate-800/80 shadow-2xl transition-all duration-500 hover:-translate-y-1">
                <div class="absolute inset-0 bg-gradient-to-br from-blue-500/20 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                <div class="absolute inset-0 p-6 flex flex-col items-center justify-center text-center z-10">
                  <div class="w-14 h-14 mb-4 rounded-2xl bg-white/5 flex items-center justify-center group-hover:bg-blue-500/20 group-hover:scale-110 transition-all duration-500">
                    <svg class="w-7 h-7 text-blue-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11.42 15.17L17.25 21A2.652 2.652 0 0021 17.25l-5.83-5.83M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                    </svg>
                  </div>
                  <span class="font-bold text-white tracking-widest text-sm">仕掛け解説</span>
                </div>
              </a>
              
              <!-- Card 2: 旬の魚 -->
              <a href="/blog/target" class="group relative block aspect-[3/4] rounded-3xl overflow-hidden bg-blue-600/80 backdrop-blur-xl border border-white/20 hover:border-white/60 shadow-2xl transition-all duration-500 hover:-translate-y-1 p-6 flex flex-col justify-end">
                <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-white/30 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                <div class="relative z-10">
                  <div class="w-12 h-12 mb-5 rounded-full bg-white/20 flex items-center justify-center backdrop-blur-md group-hover:scale-110 transition-transform duration-500 shadow-inner">
                    <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15a3 3 0 100-6 3 3 0 000 6z" />
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.5 12a7.5 7.5 0 11-15 0 7.5 7.5 0 0115 0z" />
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 2.25v2.5M12 19.25v2.5M2.25 12h2.5M19.25 12h2.5" />
                    </svg>
                  </div>
                  <span class="block font-bold text-2xl text-white leading-tight mb-2">旬の魚を<br/>狙い撃つ</span>
                  <div class="overflow-hidden h-0 group-hover:h-6 transition-all duration-300">
                    <span class="text-blue-100 text-sm font-medium flex items-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity duration-500 delay-100 whitespace-nowrap">ターゲット一覧 <span class="text-lg">→</span></span>
                  </div>
                </div>
              </a>
            </div>
            
            <div class="space-y-4 pt-8">
              <!-- Card 3: 初心者 -->
              <a href="/blog/guide" class="group relative block aspect-[3/4] rounded-3xl overflow-hidden bg-slate-800/50 backdrop-blur-xl border border-white/10 hover:border-teal-400/50 hover:bg-slate-800/80 shadow-2xl transition-all duration-500 hover:-translate-y-1 p-6 flex flex-col justify-end">
                <div class="absolute inset-0 bg-gradient-to-t from-teal-500/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                <div class="relative z-10">
                  <div class="w-12 h-12 mb-5 rounded-2xl bg-white/5 flex items-center justify-center group-hover:bg-teal-500/20 group-hover:scale-110 transition-all duration-500">
                    <svg class="w-6 h-6 text-teal-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
                    </svg>
                  </div>
                  <span class="block font-bold text-2xl text-white leading-tight mb-2">初心者も<br/>大歓迎</span>
                  <div class="overflow-hidden h-0 group-hover:h-6 transition-all duration-300">
                    <span class="text-teal-200 text-sm font-medium flex items-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity duration-500 delay-100 whitespace-nowrap">入門記事を読む <span class="text-lg">→</span></span>
                  </div>
                </div>
              </a>

              <!-- Card 4: アクセス -->
              <a href="/map" class="group relative block aspect-square rounded-3xl overflow-hidden bg-slate-700/50 backdrop-blur-xl border border-white/10 hover:border-emerald-400/50 hover:bg-slate-700/80 shadow-2xl transition-all duration-500 hover:-translate-y-1">
                <div class="absolute inset-0 bg-gradient-to-bl from-emerald-500/20 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                <div class="absolute inset-0 p-6 flex flex-col items-center justify-center text-center z-10">
                  <div class="w-14 h-14 mb-4 rounded-2xl bg-white/5 flex items-center justify-center group-hover:bg-emerald-500/20 group-hover:scale-110 transition-all duration-500">
                    <svg class="w-7 h-7 text-emerald-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
                    </svg>
                  </div>
                  <span class="font-bold text-white tracking-widest text-sm">アクセス情報</span>
                </div>
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-24 bg-blue-600 text-white text-center">
      <div class="max-w-3xl mx-auto px-4">
        <h2 class="text-4xl md:text-6xl font-black mb-8">さあ、浜名湖へ。</h2>
        <p class="text-xl mb-12 opacity-90">
          最高の釣果と、心震える体験があなたを待っています。
        </p>
        <a href="/map" class="inline-block bg-white text-blue-600 px-12 py-4 rounded-full font-black text-xl shadow-2xl transition-transform hover:scale-105 active:scale-95">
          目的地を検索する
        </a>
      </div>
    </section>
  </div>
</PageLayout>
