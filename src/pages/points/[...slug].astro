---
import { getImage } from "astro:assets"
import { type CollectionEntry, getCollection } from "astro:content"
import { buildPointArticleAndBreadcrumbJsonLd } from "@lib/jsonld"
import { withTrailingSlash } from "@lib/paths"
import PageLayout from "@layouts/PageLayout.astro"
import TopLayout from "@layouts/TopLayout.astro"
import BottomLayout from "@layouts/BottomLayout.astro"
import ArticleTopLayout from "@layouts/ArticleTopLayout.astro"
import ArticleBottomLayout from "@layouts/ArticleBottomLayout.astro"

// Create the static points pages
export async function getStaticPaths() {
	const points = await getCollection(
		"blog",
		(post) => post.data.category === "points" && !post.data.draft,
	)
	return points.map((post) => ({
		params: { slug: post.slug.replace(/^points\//, '') },
		props: post,
	}))
}

// Get the requested point
type Props = CollectionEntry<"blog">
const point = Astro.props
const { title, summary, cover, noindex } = point.data

let ogImage: string | undefined
if (cover) {
  const { src } = await getImage({ src: cover, width: 1200 })
  ogImage = src
}

const siteUrl =
  Astro.site == null
    ? "https://cho-hamanako.info"
    : typeof Astro.site === "string"
      ? Astro.site
      : Astro.site.href

const canonicalUrl = new URL(withTrailingSlash(Astro.url.pathname), Astro.site).href

const jsonLdExtra = buildPointArticleAndBreadcrumbJsonLd({
  siteUrl,
  canonicalUrl,
  post: point,
  ogImageSrc: ogImage,
})
---

<PageLayout
  title={title}
  description={summary}
  noindex={noindex}
  hasAds={true}
  image={ogImage}
  ogType="article"
  jsonLdExtra={jsonLdExtra}
>
  <TopLayout>
    <div class="animate">
      <ArticleTopLayout entry={point} />
    </div>
  </TopLayout>
  <BottomLayout>
    <div class="animate">
      <ArticleBottomLayout entry={point} />
    </div>
  </BottomLayout>
</PageLayout>